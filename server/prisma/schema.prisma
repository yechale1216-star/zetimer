generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SubscriptionPlan {
  id                      String               @id @default(uuid())
  name                    String
  slug                    String               @unique
  description             String?
  pricePerStudentMonthly  Decimal              @default(0) @db.Decimal(10, 2)
  pricePerStudentSemester Decimal              @default(0) @db.Decimal(10, 2)
  pricePerStudentYearly   Decimal              @default(0) @db.Decimal(10, 2)
  maxStudents             Int                  @default(250)
  maxUsers                Int                  @default(-1)
  isActive                Boolean              @default(true)
  isCustom                Boolean              @default(false)
  trialDays               Int                  @default(0)
  sortOrder               Int                  @default(0)
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  monthlyTotal            Decimal              @default(0) @db.Decimal(10, 2)
  semesterTotal           Decimal              @default(0) @db.Decimal(10, 2)
  yearlyTotal             Decimal              @default(0) @db.Decimal(10, 2)
  features                PlanFeature[]
  subscriptions           SchoolSubscription[]

  @@map("subscription_plans")
}

model Feature {
  id          String                  @id @default(uuid())
  key         String                  @unique
  name        String
  description String?
  category    String                  @default("general")
  isCore      Boolean                 @default(false)
  isActive    Boolean                 @default(true)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  plans       PlanFeature[]
  overrides   SchoolFeatureOverride[]

  @@map("features")
}

model PlanFeature {
  id        String           @id @default(uuid())
  planId    String
  featureId String
  createdAt DateTime         @default(now())
  feature   Feature          @relation(fields: [featureId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId])
  @@map("plan_features")
}

model SchoolSubscription {
  id              String             @id @default(uuid())
  schoolId        String             @unique
  planId          String
  billingPeriod   BillingPeriod      @default(monthly)
  studentCount    Int                @default(0)
  status          SubscriptionStatus @default(trial)
  discountPercent Decimal            @default(0) @db.Decimal(5, 2)
  billingStart    DateTime           @default(now())
  billingEnd      DateTime
  renewalDate     DateTime
  trialEndsAt     DateTime?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  plan            SubscriptionPlan   @relation(fields: [planId], references: [id])
  school          School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([planId])
  @@index([status])
  @@map("school_subscriptions")
}

model SchoolFeatureOverride {
  id        String   @id @default(uuid())
  schoolId  String
  featureId String
  granted   Boolean
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  feature   Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, featureId])
  @@index([schoolId])
  @@map("school_feature_overrides")
}

model Addon {
  id            String        @id @default(uuid())
  name          String
  description   String?
  monthlyFlat   Decimal       @db.Decimal(10, 2)
  perUnit       Boolean       @default(false)
  unitLabel     String?
  isActive      Boolean       @default(true)
  featureKey    String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  subscriptions SchoolAddon[]

  @@map("addons")
}

model SchoolAddon {
  id        String   @id @default(uuid())
  schoolId  String
  addonId   String
  quantity  Int      @default(1)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  addon     Addon    @relation(fields: [addonId], references: [id], onDelete: Cascade)
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, addonId])
  @@map("school_addons")
}

model School {
  id                   String                  @id @default(uuid())
  schoolId             String?                 @unique
  name                 String
  schoolEmail          String?
  onboardingStatus     OnboardingStatus        @default(PENDING)
  onboardingCompleted  Boolean                 @default(false)
  subscriptionStatus   String                  @default("ACTIVE")
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  attendance           Attendance[]
  callHistories        CallHistory[]
  callParticipants     CallParticipant[]
  callSessions         CallSession[]
  conversations        Conversation[]
  grades               Grade[]
  messages             Message[]
  messageReactions     MessageReaction[]
  messageReads         MessageRead[]
  parentNotifications  ParentNotification[]
  parentStudentLinks   ParentStudentLink[]
  pendingRegistrations PendingRegistration[]
  settings             SchoolSettings?
  sections             Section[]
  streams              Stream[]
  students             Student[]
  promotions           StudentPromotion[]
  teachers             Teacher[]
  assignments          TeacherAssignment[]
  users                User[]
  reports              AttendanceReport[]
  auditLogs            AuditLog[]
  addons               SchoolAddon[]
  featureOverrides     SchoolFeatureOverride[]
  subscription         SchoolSubscription?
  supportTickets       SupportTicket[]
  userNotifications    UserNotification[]
}

model User {
  id                         String               @id @default(uuid())
  email                      String               @unique
  password_hash              String
  full_name                  String
  role                       String
  phone                      String?              @unique
  is_active                  Boolean              @default(true)
  teacher_id                 String?
  schoolId                   String?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  experience_years           Int?
  qualification              String?
  subject                    String?
  profile_photo              String?
  is_verified                Boolean              @default(false)
  verification_token         String?
  verification_token_expires DateTime?
  reset_password_expires     DateTime?
  reset_password_token       String?              @unique
  address                    String?
  lastActive                 DateTime?
  pushToken                  String?
  callHistory                CallHistory[]
  callSessions               CallParticipant[]
  conversations              ConversationMember[]
  messages                   Message[]
  messageReactions           MessageReaction[]
  messageReads               MessageRead[]
  parentStudents             ParentStudentLink[]
  school                     School?              @relation(fields: [schoolId], references: [id])
  notifications              UserNotification[]

  @@index([email])
  @@index([schoolId])
}

model Teacher {
  id               String              @id @default(uuid())
  name             String
  email            String?             @unique
  schoolId         String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  experience_years Int?
  is_active        Boolean             @default(true)
  phone            String?
  qualification    String?
  subject          String?
  user_id          String?             @unique
  profile_photo    String?
  attendance       Attendance[]
  school           School?             @relation(fields: [schoolId], references: [id])
  assignments      TeacherAssignment[]

  @@index([schoolId])
}

model TeacherAssignment {
  id         String   @id @default(uuid())
  teacher_id String
  schoolId   String?
  gradeId    String
  sectionId  String
  subject    String?
  streamId   String?
  createdAt  DateTime @default(now())
  grade      Grade    @relation(fields: [gradeId], references: [id])
  school     School?  @relation(fields: [schoolId], references: [id])
  section    Section  @relation(fields: [sectionId], references: [id])
  stream     Stream?  @relation(fields: [streamId], references: [id])
  teacher    Teacher  @relation(fields: [teacher_id], references: [id])

  @@index([schoolId])
  @@index([teacher_id])
  @@index([gradeId])
  @@index([sectionId])
  @@index([streamId])
}

model SchoolSettings {
  id                   String   @id @default(uuid())
  schoolId             String?  @unique
  school_name          String?
  school_phone         String?
  school_address       String?
  academic_year        String?
  attendance_mode      String   @default("session_based")
  attendance_ui_type   String   @default("card_based")
  attendance_threshold Int      @default(75)
  allow_late_mark      Boolean  @default(true)
  email_notifications  Boolean  @default(true)
  sms_notifications    Boolean  @default(false)
  notification_time    String   @default("16:00")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  school_logo          String?
  school               School?  @relation(fields: [schoolId], references: [id])
}

model Grade {
  id             String              @id @default(uuid())
  schoolId       String?
  name           String
  school         School?             @relation(fields: [schoolId], references: [id])
  students       Student[]
  fromPromotions StudentPromotion[]  @relation("FromGrade")
  toPromotions   StudentPromotion[]  @relation("ToGrade")
  assignments    TeacherAssignment[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Section {
  id             String              @id @default(uuid())
  schoolId       String?
  name           String
  school         School?             @relation(fields: [schoolId], references: [id])
  students       Student[]
  fromPromotions StudentPromotion[]  @relation("FromSection")
  toPromotions   StudentPromotion[]  @relation("ToSection")
  assignments    TeacherAssignment[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Stream {
  id             String              @id @default(uuid())
  schoolId       String?
  name           String
  school         School?             @relation(fields: [schoolId], references: [id])
  students       Student[]
  fromPromotions StudentPromotion[]  @relation("FromStream")
  toPromotions   StudentPromotion[]  @relation("ToStream")
  assignments    TeacherAssignment[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Student {
  id                  String               @id @default(uuid())
  student_id          String
  parent_email        String
  parent_phone        String
  parent_name         String
  gender              String?
  date_of_birth       String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  fullName            String
  status              String               @default("ACTIVE")
  gradeId             String
  schoolId            String?
  sectionId           String
  streamId            String?
  address             String?
  attendance          Attendance[]
  parentNotifications ParentNotification[]
  parentStudents      ParentStudentLink[]
  grade               Grade                @relation(fields: [gradeId], references: [id])
  school              School?              @relation(fields: [schoolId], references: [id])
  section             Section              @relation(fields: [sectionId], references: [id])
  stream              Stream?              @relation(fields: [streamId], references: [id])
  promotions          StudentPromotion[]

  @@unique([student_id, schoolId])
  @@index([schoolId])
  @@index([gradeId])
  @@index([sectionId])
  @@index([streamId])
}

model StudentPromotion {
  id               String   @id @default(uuid())
  schoolId         String
  studentId        String
  academicYear     String
  fromGradeId      String
  fromSectionId    String
  toGradeId        String?
  toSectionId      String?
  fromStreamId     String?
  toStreamId       String?
  promotedByUserId String
  promotedAt       DateTime @default(now())
  notes            String?
  fromGrade        Grade    @relation("FromGrade", fields: [fromGradeId], references: [id])
  fromSection      Section  @relation("FromSection", fields: [fromSectionId], references: [id])
  fromStream       Stream?  @relation("FromStream", fields: [fromStreamId], references: [id])
  school           School   @relation(fields: [schoolId], references: [id])
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  toGrade          Grade?   @relation("ToGrade", fields: [toGradeId], references: [id])
  toSection        Section? @relation("ToSection", fields: [toSectionId], references: [id])
  toStream         Stream?  @relation("ToStream", fields: [toStreamId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([fromGradeId])
  @@index([toGradeId])
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  date      DateTime @default(now())
  status    String
  session   String?
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  schoolId  String?
  teacherId String?
  school    School?  @relation(fields: [schoolId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([schoolId])
  @@index([date])
  @@index([session])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(uuid())
  schoolId    String?
  user_id     String?
  action      String
  entity_type String
  entity_id   String?
  old_values  Json?
  new_values  Json?
  created_at  DateTime @default(now())
  school      School?  @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("audit_logs")
}

model AttendanceReport {
  id                    String   @id @default(uuid())
  schoolId              String?
  student_id            String
  class_id              String
  month                 Int
  year                  Int
  total_days            Int      @default(0)
  present_days          Int      @default(0)
  absent_days           Int      @default(0)
  late_days             Int      @default(0)
  leave_days            Int      @default(0)
  attendance_percentage Decimal  @default(0.00) @db.Decimal(5, 2)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  school                School?  @relation(fields: [schoolId], references: [id])

  @@unique([student_id, month, year])
  @@index([schoolId])
  @@map("attendance_reports")
}

model ParentStudentLink {
  id               String   @id @default(uuid())
  schoolId         String?
  parentId         String
  studentId        String
  relationshipType String?  @default("Guardian")
  createdAt        DateTime @default(now())
  parent           User     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  school           School?  @relation(fields: [schoolId], references: [id])
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@index([parentId])
  @@index([schoolId])
}

model ParentNotification {
  id        String   @id @default(uuid())
  schoolId  String?
  studentId String?
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  school    School?  @relation(fields: [schoolId], references: [id])
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
}

model ParentPreferences {
  id                 String   @id @default(uuid())
  parentPhone        String
  emailNotifications Boolean  @default(true)
  smsNotifications   Boolean  @default(false)
  pushNotifications  Boolean  @default(true)
  updatedAt          DateTime @updatedAt
  schoolId           String?

  @@unique([parentPhone, schoolId])
}

model Conversation {
  id              String               @id @default(uuid())
  name            String?
  isGroup         Boolean              @default(false)
  avatar          String?
  description     String?
  groupType       String?              // GRADE | PARENT | TEACHER | STAFF | ANNOUNCEMENT | CUSTOM
  isAnnouncement  Boolean              @default(false)
  createdBy       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  schoolId        String?
  school          School?              @relation(fields: [schoolId], references: [id])
  members         ConversationMember[]
  messages        Message[]
  pinnedMessages  PinnedMessage[]

  @@index([schoolId])
}

model ConversationMember {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  role           String       @default("MEMBER") // OWNER | ADMIN | MEMBER
  isMuted        Boolean      @default(false)
  mutedUntil     DateTime?
  lastSeenAt     DateTime?
  nickname       String?
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@index([userId, conversationId])     // presence scoping: find all convs for a user
}

model Message {
  id               String            @id @default(uuid())
  schoolId         String?
  conversationId   String
  senderId         String
  content          String?
  type             String            @default("TEXT")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  editedAt         DateTime?
  isDeleted        Boolean           @default(false)
  replyToId        String?
  forwardedFromId  String?
  attachments      Json?
  metadata         Json?
  conversation     Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyTo          Message?          @relation("Replies", fields: [replyToId], references: [id])
  replies          Message[]         @relation("Replies")
  school           School?           @relation(fields: [schoolId], references: [id])
  sender           User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reactions        MessageReaction[]
  readBy           MessageRead[]
  pinnedIn         PinnedMessage[]

  @@index([conversationId])
  @@index([conversationId, createdAt])   // message pagination — avoids full-table sort
  @@index([schoolId, conversationId])    // tenant-scoped conversation message fetch
  @@index([senderId])
  @@index([schoolId])
}

model PinnedMessage {
  id             String       @id @default(uuid())
  conversationId String
  messageId      String
  pinnedBy       String
  pinnedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([conversationId, messageId])
  @@index([conversationId])
}

model MessageRead {
  id        String   @id @default(uuid())
  schoolId  String?
  messageId String
  userId    String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  school    School?  @relation(fields: [schoolId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@index([schoolId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  schoolId  String?
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  school    School?  @relation(fields: [schoolId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
  @@index([schoolId])
}

model CallSession {
  id             String            @id @default(uuid())
  schoolId       String?
  conversationId String?
  type           String            @default("VOICE")
  status         String            @default("ONGOING")
  startTime      DateTime          @default(now())
  endTime        DateTime?
  createdAt      DateTime          @default(now())
  history        CallHistory[]
  participants   CallParticipant[]
  school         School?           @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
}

model CallParticipant {
  id            String      @id @default(uuid())
  schoolId      String?
  callSessionId String
  userId        String
  joinedAt      DateTime    @default(now())
  leftAt        DateTime?
  callSession   CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  school        School?     @relation(fields: [schoolId], references: [id])
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([callSessionId, userId])
  @@index([schoolId])
}

model CallHistory {
  id            String      @id @default(uuid())
  schoolId      String?
  userId        String
  callSessionId String
  type          String
  status        String
  duration      Int?
  createdAt     DateTime    @default(now())
  callSession   CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  school        School?     @relation(fields: [schoolId], references: [id])
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
}

model PendingRegistration {
  id            String   @id
  schoolId      String?
  email         String   @unique
  password_hash String
  full_name     String
  role          String
  phone         String?
  school_name   String?
  token         String   @unique
  expires_at    DateTime
  createdAt     DateTime @default(now())
  school        School?  @relation(fields: [schoolId], references: [id])

  @@index([email])
  @@index([token])
  @@index([schoolId])
}

model PlatformConfig {
  id               String   @id @default("singleton")
  platformName     String   @default("Zetime")
  supportEmail     String   @default("support@zetime.io")
  maintenanceMode  Boolean  @default(false)
  autoBackup       Boolean  @default(true)
  apiRateLimit     Int      @default(1000)
  maxUploadSize    Int      @default(50)
  trialEnabled     Boolean  @default(true)
  trialDuration    Int      @default(14)
  trialCapacity    Int      @default(100)
  updatedAt        DateTime @updatedAt
  maxLoginAttempts Int      @default(5)
  sessionTimeout   Int      @default(30)
  twoFactorEnabled Boolean  @default(false)

  @@map("platform_configs")
}

model SupportTicket {
  id           String   @id @default(cuid())
  ticketNumber String   @unique
  schoolId     String
  authorId     String?
  subject      String
  description  String
  category     String   @default("General")
  status       String   @default("open")
  priority     String   @default("normal")
  assignee     String?
  resolution   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([status])
  @@map("support_tickets")
}

model BroadcastLog {
  id        String   @id @default(cuid())
  title     String
  content   String
  type      String   @default("info")
  sentCount Int      @default(0)
  sentAt    DateTime @default(now())

  @@map("broadcast_logs")
}

enum OnboardingStatus {
  PENDING
  ACTIVE
  SETUP_COMPLETE
}

enum BillingPeriod {
  monthly
  semester
  yearly
}

enum SubscriptionStatus {
  active
  trial
  expired
  suspended
  pending_payment
  expiring
  cancelled
  paused
}

model UserNotification {
  id        String   @id @default(uuid())
  schoolId  String?
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  school    School?  @relation(fields: [schoolId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([userId])
}
