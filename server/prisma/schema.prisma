generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id                  String               @id @default(uuid())
  name                String               @unique
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  attendance          Attendance[]
  parentNotifications ParentNotification[]
  settings            SchoolSettings?
  students            Student[]
  teachers            Teacher[]
  assignments         TeacherAssignment[]
  users               User[]
}

model User {
  id               String              @id @default(uuid())
  email            String              @unique
  password_hash    String
  full_name        String
  role             String
  phone            String?
  is_active        Boolean             @default(true)
  teacher_id       String?
  school_id        String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  experience_years Int?
  qualification    String?
  subject          String?
  profile_photo    String?
  parentStudents   ParentStudentLink[]
  school           School?             @relation(fields: [school_id], references: [id])
  conversations    ConversationMember[]
  messages         Message[]
  messageReads     MessageRead[]
  messageReactions MessageReaction[]
  callSessions     CallParticipant[]
  callHistory      CallHistory[]

  @@index([email])
  @@index([school_id])
}

model Teacher {
  id               String              @id @default(uuid())
  name             String
  email            String?             @unique
  schoolId         String
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  experience_years Int?
  is_active        Boolean             @default(true)
  phone            String?
  qualification    String?
  subject          String?
  user_id          String?             @unique
  profile_photo    String?
  attendance       Attendance[]
  school           School              @relation(fields: [schoolId], references: [id])
  assignments      TeacherAssignment[]

  @@index([schoolId])
}

model TeacherAssignment {
  id         String   @id @default(uuid())
  teacher_id String
  school_id  String
  grade      String
  section    String
  subject    String?
  stream     String?
  createdAt  DateTime @default(now())
  school     School   @relation(fields: [school_id], references: [id])
  teacher    Teacher  @relation(fields: [teacher_id], references: [id])

  @@index([school_id])
  @@index([teacher_id])
}

model SchoolSettings {
  id                   String   @id @default(uuid())
  school_id            String   @unique
  school_name          String?
  school_phone         String?
  school_address       String?
  academic_year        String?
  attendance_mode      String   @default("session_based")
  attendance_ui_type   String   @default("card_based")
  attendance_threshold Int      @default(75)
  allow_late_mark      Boolean  @default(true)
  email_notifications  Boolean  @default(true)
  sms_notifications    Boolean  @default(false)
  notification_time    String   @default("16:00")
  school_logo          String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  school               School   @relation(fields: [school_id], references: [id])
}

model Grade {
  id       String    @id @default(uuid())
  name     String    @unique
  students Student[]
}

model Section {
  id       String    @id @default(uuid())
  name     String    @unique
  students Student[]
}

model Stream {
  id       String    @id @default(uuid())
  name     String    @unique
  students Student[]
}

model Student {
  id                  String               @id @default(uuid())
  student_id          String               @unique
  parent_email        String
  parent_phone        String
  parent_name         String
  gender              String?
  date_of_birth       String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  fullName            String
  gradeId             String
  schoolId            String
  sectionId           String
  streamId            String?
  attendance          Attendance[]
  parentNotifications ParentNotification[]
  parentStudents      ParentStudentLink[]
  grade               Grade                @relation(fields: [gradeId], references: [id])
  school              School               @relation(fields: [schoolId], references: [id])
  section             Section              @relation(fields: [sectionId], references: [id])
  stream              Stream?              @relation(fields: [streamId], references: [id])

  @@index([schoolId])
  @@index([gradeId])
  @@index([sectionId])
  @@index([streamId])
}

model Attendance {
  id        String   @id @default(uuid())
  studentId String
  date      DateTime @default(now())
  status    String
  session   String?
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  schoolId  String
  teacherId String?
  school    School   @relation(fields: [schoolId], references: [id])
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher   Teacher? @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([schoolId])
  @@index([date])
  @@index([session])
  @@index([status])
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String?
  action      String
  entity_type String
  entity_id   String?
  old_values  Json?
  new_values  Json?
  created_at  DateTime @default(now())

  @@map("audit_logs")
}

model AttendanceReport {
  id                    String   @id @default(uuid())
  student_id            String
  class_id              String
  month                 Int
  year                  Int
  total_days            Int      @default(0)
  present_days          Int      @default(0)
  absent_days           Int      @default(0)
  late_days             Int      @default(0)
  leave_days            Int      @default(0)
  attendance_percentage Decimal  @default(0.00) @db.Decimal(5, 2)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  @@unique([student_id, month, year])
  @@map("attendance_reports")
}

model ParentStudentLink {
  id               String   @id @default(uuid())
  parentId         String
  studentId        String
  relationshipType String?  @default("Guardian")
  createdAt        DateTime @default(now())
  parent           User     @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student          Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@index([parentId])
  @@index([studentId])
}

model ParentNotification {
  id        String   @id @default(uuid())
  schoolId  String
  studentId String?
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  school    School   @relation(fields: [schoolId], references: [id])
  student   Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
}

model ParentPreferences {
  id                 String   @id @default(uuid())
  parentPhone        String   @unique
  emailNotifications Boolean  @default(true)
  smsNotifications   Boolean  @default(false)
  pushNotifications  Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}

model Conversation {
  id        String               @id @default(uuid())
  name      String?
  isGroup   Boolean              @default(false)
  avatar    String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  members   ConversationMember[]
  messages  Message[]
}

model ConversationMember {
  id             String       @id @default(uuid())
  conversationId String
  userId         String
  role           String       @default("MEMBER") // ADMIN, MEMBER
  joinedAt       DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
}

model Message {
  id             String            @id @default(uuid())
  conversationId String
  senderId       String
  content        String?
  type           String            @default("TEXT") // TEXT, IMAGE, FILE, VOICE
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User              @relation(fields: [senderId], references: [id], onDelete: Cascade)
  readBy         MessageRead[]
  reactions      MessageReaction[]
  attachments    Attachment[]
  replyToId      String?
  replyTo        Message?          @relation("Replies", fields: [replyToId], references: [id])
  replies        Message[]         @relation("Replies")

  @@index([conversationId])
  @@index([senderId])
}

model MessageRead {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
}

model Attachment {
  id        String   @id @default(uuid())
  messageId String
  url       String
  name      String
  type      String
  size      Int
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model CallSession {
  id             String            @id @default(uuid())
  conversationId String?
  type           String            @default("VOICE") // VOICE, VIDEO
  status         String            @default("ONGOING") // ONGOING, ENDED, MISSED
  startTime      DateTime          @default(now())
  endTime        DateTime?
  participants   CallParticipant[]
  history        CallHistory[]
  createdAt      DateTime          @default(now())
}

model CallParticipant {
  id            String      @id @default(uuid())
  callSessionId String
  userId        String
  joinedAt      DateTime    @default(now())
  leftAt        DateTime?
  callSession   CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([callSessionId, userId])
}

model CallHistory {
  id            String      @id @default(uuid())
  userId        String
  callSessionId String
  type          String // INCOMING, OUTGOING, MISSED
  status        String // COMPLETED, MISSED, REJECTED
  duration      Int? // in seconds
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  callSession   CallSession @relation(fields: [callSessionId], references: [id], onDelete: Cascade)
}
